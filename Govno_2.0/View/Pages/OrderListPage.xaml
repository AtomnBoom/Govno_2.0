<Page x:Class="Govno_2._0.View.Pages.OrderListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Govno_2._0.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="830" d:DesignWidth="1180"
      Title="OrderListPage">

    <Grid>
        <ListBox Name="OrdersList" 
                 Background="Transparent" 
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="30" Height="150" Width="530" Background="#D0D0D0" Margin="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>

                            <Border CornerRadius="30" ClipToBounds="True">
                                <Image Stretch="UniformToFill">
                                    <Image.Source>
                                        <Binding Path="Photo">
                                            <Binding.TargetNullValue>
                                                <BitmapImage UriSource="/Resources/imageselect.png"/>
                                            </Binding.TargetNullValue>
                                        </Binding>
                                    </Image.Source>
                                </Image>
                            </Border>

                            <StackPanel Grid.Column="1" Grid.ColumnSpan="2" Margin="15,10,0,0">
                                <TextBlock Text="{Binding Number, StringFormat=Заказ №{0}}" 
                                           FontSize="24" 
                                           FontFamily="Times New Roman" 
                                           Foreground="#F70129" 
                                           FontWeight="Bold"/>

                                <TextBlock Text="{Binding Name}" 
                                           FontSize="18" 
                                           FontFamily="Times New Roman" 
                                           TextWrapping="Wrap"/>

                                <TextBlock FontSize="16" FontFamily="Times New Roman" Margin="0,5,0,0">
                                    <Run Text="Заказчик: "/>
                                    <Run Text="{Binding Clients.FullName}"/>
                                </TextBlock>

                                <TextBlock Text="{Binding TotalPrice, StringFormat=Стоимость – {0} руб}" 
                                           FontSize="18" 
                                           FontFamily="Times New Roman" 
                                           Foreground="#F70129"
                                           Margin="0,5,0,0"/>

                                <Border Background="#F70129" 
                                        CornerRadius="15" 
                                        HorizontalAlignment="Left"
                                        Margin="0,5,0,0" Height="30" Width="150">
                                    <Button Content="Подтвердить" 
                                            Background="Transparent" 
                                            BorderThickness="0"
                                            Foreground="White"
                                            FontSize="16"
                                            FontFamily="Times New Roman"
                                            Click="AcceptBtn_Click"/>
                                </Border>
                            </StackPanel>

                            <Button Grid.Column="2" 
                                    Background="Transparent" 
                                    BorderThickness="0" 
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,10,10"
                                    Click="DeleteBtn_Click">
                                <Image Source="/Resources/Delete.png" Width="40"/>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" MaxWidth="1100"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
    </Grid>
</Page>