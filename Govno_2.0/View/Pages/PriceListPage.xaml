<Page x:Class="Govno_2._0.View.Pages.PriceListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Govno_2._0.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="830" d:DesignWidth="1180"
      Title="PriceListPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <ListBox Name="GroupsList" 
                 Background="Transparent" 
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 BorderThickness="0"
                 Grid.RowSpan="2">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <Border Background="#F70129" 
                                CornerRadius="15 15 15 15" 
                                Height="35" 
                                Width="1150" 
                                HorizontalAlignment="Left"
                                Margin="5,10,5,0">
                            <TextBlock Text="{Binding Name}" 
                                       FontSize="26" 
                                       FontFamily="Times New Roman" 
                                       FontWeight="Bold" 
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       Margin="20,0,0,0"/>
                        </Border>

                        <ItemsControl ItemsSource="{Binding Services}" 
                                      Margin="5,5,5,15">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="1150" Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="150" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Name}" 
                                                   FontSize="24"
                                                   FontFamily="Times New Roman"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0,0,0"/>

                                        <TextBlock Grid.Column="1" 
                                                   HorizontalAlignment="Right"
                                                   Margin="0,0,20,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontSize" Value="24"/>
                                                    <Setter Property="FontFamily" Value="Times New Roman"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Price}" Value="0">
                                                            <Setter Property="Text" Value="договорная"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} руб.">
                                                    <Binding Path="Price"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Name="HideAdd" Grid.Row="1" HorizontalAlignment="Right" Background="#F70129" 
             Width="200" Margin="0 25 0 0" CornerRadius="30 0 0 0" MouseEnter="HideAdd_MouseEnter"/>

        <Border Name="VisibleAdd" Grid.Row="1" HorizontalAlignment="Right" Background="#F70129" 
             Width="200" CornerRadius="30 0 0 0" Visibility="Collapsed" MouseLeave="VisibleAdd_MouseLeave">

            <Button Name="EditServiceBtn" Background="Transparent" Content="Редактировать" 
                 FontSize="20" FontFamily="Times New Roman"  BorderThickness="0" 
                 Foreground="White" FontWeight="Bold" Click="EditServiceBtn_Click"/>
        </Border>

    </Grid>
</Page>
