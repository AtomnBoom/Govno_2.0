<Page x:Class="Govno_2._0.View.Pages.ProfilPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Govno_2._0.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="830" d:DesignWidth="1180"
      Title="ProfilPage">

    <Grid Background="#E8E8E8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Border Background="White" Grid.Column="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,50,0,0">
                    <Button Name="MenuSupport"
                       Content="Техническая&#x0a;поддержка" 
                       FontSize="36" 
                       FontFamily="Times New Roman"
                       Margin="20,10"
                       Cursor="Hand"
                       Style="{StaticResource NemuBtn}" 
                       MouseLeftButtonUp="Support_Click"/>

                    <Rectangle Height="2" Fill="#CCCCCC" Margin="15,5"/>

                    <TextBlock Name="MenuProfile" 
                       Text="Личный&#x0a;кабинет" 
                       FontSize="36" 
                       FontFamily="Times New Roman"
                       FontWeight="Bold"
                       Foreground="#F70129"
                       Margin="20,15"
                       Cursor="Hand"
                       HorizontalAlignment="Center"/>

                    <Button Name="MenuSettings" 
                       Content="Настройки" 
                       FontSize="36" 
                       FontFamily="Times New Roman"
                       Margin="20,15"
                       Cursor="Hand"
                       Style="{StaticResource NemuBtn}" 
                       MouseLeftButtonUp="Settings_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Background="#E8E8E8" Grid.Column="1">
            <StackPanel HorizontalAlignment="Center" 
                    VerticalAlignment="Center" 
                    Width="500">

                <Ellipse Width="250" 
                     Height="250" 
                     Fill="#5A6B8C"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Margin="0,0,0,30">
                </Ellipse>

                <TextBlock Text="👤" 
                       FontSize="120" 
                       HorizontalAlignment="Center"
                       Margin="0,-240,0,70"
                       IsHitTestVisible="False"
                       Foreground="White">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentUser.Photo}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Grid Margin="-90,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Right">
                        <TextBlock Text="Имя" FontSize="28" FontFamily="Times New Roman" Margin="0,8"/>
                        <TextBlock Text="Фамилия" FontSize="28" FontFamily="Times New Roman" Margin="0,8"/>
                        <TextBlock Text="Отчество" FontSize="28" FontFamily="Times New Roman" Margin="0,8"/>
                        <TextBlock Text="Должность" FontSize="28" FontFamily="Times New Roman" Margin="0,8"/>
                        <TextBlock Text="Зарплата" FontSize="28" FontFamily="Times New Roman" Margin="0,8"/>
                        <TextBlock Text="График работы : " FontSize="28" FontFamily="Times New Roman"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="-" FontSize="28" FontFamily="Times New Roman" Margin="0,8"/>
                        <TextBlock Text="-" FontSize="28" FontFamily="Times New Roman" Margin="0,8"/>
                        <TextBlock Text="-" FontSize="28" FontFamily="Times New Roman" Margin="0,8"/>
                        <TextBlock Text="-" FontSize="28" FontFamily="Times New Roman" Margin="0,8"/>
                        <TextBlock Text="-" FontSize="28" FontFamily="Times New Roman" Margin="0,8"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding CurrentUser.Name}" 
                               FontSize="28" FontFamily="Times New Roman" Margin="0,8"/>
                        <TextBlock Text="{Binding CurrentUser.LastName}" 
                               FontSize="28" FontFamily="Times New Roman" Margin="0,8"/>
                        <TextBlock Text="{Binding CurrentUser.SecondName}" 
                               FontSize="28" FontFamily="Times New Roman" Margin="0,8"/>
                        <TextBlock Text="{Binding CurrentUser.UserType.Name}" 
                               FontSize="28" FontFamily="Times New Roman" Margin="0,8"/>
                        <TextBlock Text="{Binding CurrentUser.UserType.PayCount, StringFormat={}{0} руб.}" 
                               FontSize="28" FontFamily="Times New Roman" Margin="0,8"/>
                        <TextBlock Text="{Binding CurrentUser.UserType.DaysWorks}" FontSize="24" FontFamily="Times New Roman"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Page>