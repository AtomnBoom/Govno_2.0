<Window x:Class="Govno_2._0.View.Windows.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Govno_2._0.View.Windows"
        xmlns:wpfAnimatedGif="http://wpfanimatedgif.codeplex.com"
        mc:Ignorable="d"
        Title="Login" Height="300" Width="500" WindowStartupLocation="CenterScreen" WindowStyle="None" Background="Transparent" AllowsTransparency="True">
    <Grid>
        <Border Background="#ECECEC" CornerRadius="50" BorderBrush="Black" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50" />
                    <RowDefinition Height="55" />
                    <RowDefinition Height="55" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="40" />
                </Grid.RowDefinitions>
                <Label Grid.Row="1" Content="Авторизация"  FontSize="36" FontFamily="Times New Roman" HorizontalAlignment="Center"/>
                <Label Grid.Row="2" Content="успешна"  FontSize="36" FontFamily="Times New Roman" HorizontalAlignment="Center"/>
                <Image Name="gif" Grid.Row="4" Width="100" Source="\Resources\verified.gif" wpfAnimatedGif:ImageBehavior.AnimatedSource="\Resources\verified.gif"/>
            </Grid>
        </Border>
    </Grid>
</Window>
