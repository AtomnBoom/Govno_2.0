<Window x:Class="Govno_2._0.View.Windows.Edit.SelectClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Govno_2._0.View.Windows.Edit"
        mc:Ignorable="d"
        Title="SelectClient" Height="450" Width="550" WindowStyle="None" Background="Transparent" AllowsTransparency="True" WindowStartupLocation="CenterScreen">
    <Border Background="#ECECEC" CornerRadius="50" Padding="20 5" BorderBrush="Black" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="25" />
                <RowDefinition Height="40" />
                <RowDefinition Height="15" />
                <RowDefinition Height="40" />
                <RowDefinition Height="15" />
                <RowDefinition Height="200" />
                <RowDefinition Height="15" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <Button Name="CancelBtn" BorderThickness="0" Background="Transparent" Click="CancelBtn_Click" HorizontalAlignment="Left" Margin="15 3">
                <Image Source="/Resources/Cancel.png"/>
            </Button>

            <Label Content="Выбор Клиента" FontSize="24" FontFamily="Times New Roman" HorizontalAlignment="Center" Foreground="red"/>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Поиск -" FontSize="20" FontFamily="Times New Roman" Background="Transparent" VerticalAlignment="Center"/>
                <Border Grid.Column="1" Background="White" CornerRadius="15" Margin="0 5">
                    <TextBox Name="SearchTxt" BorderThickness="0" Background="Transparent" Margin="15 0" TextChanged="SearchTxt_TextChanged"/>
                </Border>
            </Grid>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Телефон -" FontSize="20" FontFamily="Times New Roman" Background="Transparent" VerticalAlignment="Center"/>
                <Border Grid.Column="1" Background="White" CornerRadius="15" Margin="0 5">
                    <TextBlock Name="PhoneTbl" Text="{Binding Phone}" FontSize="18" FontFamily="Times New Roman" Background="Transparent" Margin="15 0" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <Border Grid.Row="6" Background="White" CornerRadius="15" BorderBrush="Black" BorderThickness="1">
                <ListBox Name="ClientsList" Background="Transparent" BorderThickness="0" SelectionChanged="ClientsList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#D0D0D0" BorderThickness="0 0 0 1" Padding="5">
                                <StackPanel>
                                    <TextBlock Text="{Binding FullName}" FontSize="16" FontFamily="Times New Roman" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Phone}" FontSize="14" FontFamily="Times New Roman" Foreground="Gray"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Grid Grid.Row="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="15" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border CornerRadius="20" Background="#F70129">
                    <Button Name="AddNewClientBtn" Background="Transparent" FontSize="16" FontFamily="Times New Roman" BorderThickness="0" Foreground="White" Content="Новый клиент" FontWeight="Bold" Click="AddNewClientBtn_Click"/>
                </Border>

                <Border Grid.Column="2" CornerRadius="20" Background="#F70129">
                    <Button Name="SelectBtn" Background="Transparent" FontSize="16" FontFamily="Times New Roman" BorderThickness="0" Foreground="White" Content="Выбрать" FontWeight="Bold" Click="SelectBtn_Click"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>