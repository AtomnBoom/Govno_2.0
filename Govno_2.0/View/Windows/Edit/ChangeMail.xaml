<Window x:Class="Govno_2._0.View.Windows.Edit.ChangeMail"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Govno_2._0.View.Windows.Edit"
        mc:Ignorable="d"
        Title="ChangeMail" Height="300" Width="500" WindowStyle="None" Background="Transparent">
    <Grid>
        <Border Background="#ECECEC" CornerRadius="50">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>

                <Label Content="СМЕНА ПАРОЛЯ"  FontSize="20" FontFamily="Times New Roman" HorizontalAlignment="Center" />
                <Label Grid.Row="1" Content="Авторизация"  FontSize="36" FontFamily="Times New Roman" HorizontalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
