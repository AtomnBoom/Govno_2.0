<Window x:Class="Govno_2._0.View.Windows.Edit.EditOrder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Govno_2._0.View.Windows.Edit"
        mc:Ignorable="d"
        Title="EditOrder"  Height="400" Width="600" WindowStyle="None" Background="Transparent" AllowsTransparency="True">
    <Grid>
        <Border Background="#ECECEC" CornerRadius="50" Padding="20 5" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="25" />
                    <RowDefinition Height="25" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="200" />
                </Grid.RowDefinitions>

                <Button Name="CancelBtn" BorderThickness="0" Background="Transparent" Click="CancelBtn_Click" HorizontalAlignment="Left" Margin="15 3">
                    <Image Source="/Resources/Cancel.png"/>
                </Button>

                <Label Content="Заказ №"  FontSize="24" FontFamily="Times New Roman" HorizontalAlignment="Center" Foreground="red"/>

                <TextBox Text="Заголовок(наименование услуг)" FontSize="20" FontFamily="Times New Roman" Grid.Row="1" Background="Transparent" HorizontalAlignment="Center" BorderThickness="0"/>

                <TextBlock Text="Перечень выбранных услуг:" FontSize="20" FontFamily="Times New Roman" Grid.Row="2" Background="Transparent" HorizontalAlignment="Left"/>

                <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                    <ItemsControl Name="ServicesList" ItemsSource="{Binding }">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <Button Tag="{Binding Id}" Name="RemoveBtn" BorderThickness="0" Background="Transparent" Click="RemoveBtn_Click">
                                        <Image Source="/Resources/REMOVE.png" HorizontalAlignment="Center"/>
                                    </Button>
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontFamily="Times New Roman" Grid.Column="1"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Name="AddServiceBtn" Grid.Row="5" Background="Transparent" HorizontalAlignment="Left" BorderThickness="0" Margin="1 0" Click="AddServiceBtn_Click">
                    <Image Source="/Resources/ADD.png" />
                </Button>

                <Grid Grid.Row="7">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="15" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="35" />
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="15" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.RowSpan="5" BorderThickness="1" BorderBrush="Black">
                        <Image Source="/Resources/imageselect.png" Height="70"/>
                    </Border>

                    <Grid Grid.Column="2" Grid.ColumnSpan="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="85" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Заказчик:" FontSize="20" FontFamily="Times New Roman" Background="Transparent" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="White" CornerRadius="20" Margin="0 5">
                            <TextBox BorderThickness="0" Background="Transparent" Margin="15 0"/>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="2" Grid.ColumnSpan="4" Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="55" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Дата:" FontSize="20" FontFamily="Times New Roman" Background="Transparent" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="White" CornerRadius="20" Margin="0 5">
                            <DatePicker BorderThickness="0" Background="Transparent" Margin="5 3"/>
                        </Border>
                    </Grid>

                    <Button Name="DeleteBtn" Grid.Row="4" Grid.Column="2" Background="Transparent" BorderThickness="0" Click="DeleteBtn_Click" Visibility="Collapsed">
                        <Image Source="/Resources/Delete.png" Width="50" HorizontalAlignment="Center"/>
                    </Button>

                    <Border Grid.Row="4" Grid.Column="4" CornerRadius="20" Background="#F70129" Margin="0 5">
                        <Button Name="SaveBtn" Background="Transparent" FontSize="18" FontFamily="Times New Roman"  BorderThickness="0" Foreground="White" Content="Добавить заказ" FontWeight="Bold" Click="SaveBtn_Click"/>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>