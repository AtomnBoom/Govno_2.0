<Window x:Class="Govno_2._0.View.Windows.MainWindows"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Govno_2._0.View.Windows"
        mc:Ignorable="d"
        Title="MainWindows"  Height="900" Width="1200" WindowStartupLocation="CenterScreen">
    <Grid Background="#ECECEC">
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Grid Background="White">
            <Image Height="60" Width="120" HorizontalAlignment="Left" Source="\Resources\Logo.png" Margin="15 0"/>
        </Grid>
        <Frame Name="MainF" Grid.Row="1"/>
    </Grid>
</Window>
