<Window x:Class="Govno_2._0.View.Windows.Registration2Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Govno_2._0.View.Windows"
        mc:Ignorable="d"
        Title="Регистрация" Height="900" Width="1200" WindowStartupLocation="CenterScreen">
    <Grid Background="#ECECEC">
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Grid Background="White">
            <Button Name="CancelBtn" Background="Transparent" Height="60" Width="120" HorizontalAlignment="Left" Margin="15 0" BorderThickness="0" Click="CancelBtn_Click">
                <Image Source="\Resources\Logo.png"/>
            </Button>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="10" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="60" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="60" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="60" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="60" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="60" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="60" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="60" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>

                <TextBlock Text="РЕГИСТРАЦИЯ" HorizontalAlignment="Center" FontSize="28" Grid.Row="1" FontFamily="Times New Roman" FontWeight="SemiBold"/>

                <TextBlock Grid.Row="3" Text="Фамилия" FontSize="28" FontFamily="Times New Roman" Margin="20 0" VerticalAlignment="Center"/>
                <Border Grid.Row="4" CornerRadius="20" Background="#E3E3E3" Margin="0 5">
                    <TextBox Name="SnameTb" Background="Transparent" FontSize="24" FontFamily="Times New Roman" VerticalContentAlignment="Center" BorderThickness="0" Margin="20 0"/>
                </Border>

                <TextBlock Grid.Row="5" Text="Имя" FontSize="28" FontFamily="Times New Roman" Margin="20 0" VerticalAlignment="Center"/>
                <Border Grid.Row="6" CornerRadius="20" Background="#E3E3E3" Margin="0 5">
                    <TextBox Name="NameTb" Background="Transparent" FontSize="24" FontFamily="Times New Roman"  BorderThickness="0" Margin="20 0"  VerticalContentAlignment="Center"/>
                </Border>

                <TextBlock Grid.Row="7" Text="Отчество" FontSize="28" FontFamily="Times New Roman" Margin="20 0" VerticalAlignment="Center"/>
                <Border Grid.Row="8" CornerRadius="20" Background="#E3E3E3" Margin="0 5">
                    <TextBox Name="LnameTb" Background="Transparent" FontSize="24" FontFamily="Times New Roman"  BorderThickness="0" Margin="20 0"  VerticalContentAlignment="Center"/>
                </Border>

                <TextBlock Grid.Row="9" Text="Дослжность" FontSize="28" FontFamily="Times New Roman" Margin="20 0" VerticalAlignment="Center"/>
                <Border Grid.Row="10" CornerRadius="20" Background="#E3E3E3" Margin="0 5">
                    <ComboBox Name="RoleCmb" Background="Transparent" FontSize="24" FontFamily="Times New Roman" BorderThickness="0" Margin="20 0"  VerticalContentAlignment="Center" />
                </Border>

                <TextBlock Grid.Row="11" Text="Почта" FontSize="28" FontFamily="Times New Roman" Margin="20 0" VerticalAlignment="Center"/>
                <Border Grid.Row="12" CornerRadius="20" Background="#E3E3E3" Margin="0 5">
                    <TextBox Name="MailTb" Background="Transparent" FontSize="24" FontFamily="Times New Roman"  BorderThickness="0" Margin="20 0"  VerticalContentAlignment="Center"/>
                </Border>

                <TextBlock Grid.Row="13" Text="Телефон" FontSize="28" FontFamily="Times New Roman" Margin="20 0" VerticalAlignment="Center"/>
                <Border Grid.Row="14" CornerRadius="20" Background="#E3E3E3" Margin="0 5">
                    <TextBox Name="PhoneTb" Background="Transparent" FontSize="24" FontFamily="Times New Roman"  BorderThickness="0" Margin="20 0"  VerticalContentAlignment="Center"/>
                </Border>

                <Border Grid.Row="16" CornerRadius="20" Background="#F70129" Margin="0 5">
                    <Button Name="RegBtn" Background="Transparent" FontSize="28" FontFamily="Times New Roman"  BorderThickness="0" Margin="20 0" Foreground="White" Content="Отправить запрос" Click="RegBtn_Click"/>
                </Border>
            </Grid>

            <Image Grid.Column="2" Source="/Resources/Man.png" Height="400" VerticalAlignment="Bottom"/>
        </Grid>
    </Grid>
</Window>
